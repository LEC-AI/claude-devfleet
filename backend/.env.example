# ── Required for production ────────────────────────────────────────────────

# JWT secret — generate with: openssl rand -hex 32
DEVFLEET_JWT_SECRET=replace-with-64-char-random-string

# First admin (seeded on first boot if users table is empty)
DEVFLEET_ADMIN_EMAIL=you@example.com
DEVFLEET_ADMIN_PASSWORD=change-me-immediately

# CORS — comma-separated allowed origins (no trailing slashes)
# Add your Netlify URL here
DEVFLEET_ALLOWED_ORIGINS=https://yourapp.netlify.app,http://localhost:3100,http://localhost:3101

# ── Optional ──────────────────────────────────────────────────────────────

# Anthropic API key (if not already set in shell profile)
ANTHROPIC_API_KEY=sk-ant-...

# Max concurrent agents (0 = defer to per-lane limits)
DEVFLEET_MAX_AGENTS=0
