<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.farhan.devfleet-ui</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/npx</string>
        <string>vite</string>
        <string>--port</string>
        <string>3100</string>
        <string>--host</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/moofasa/claude-devfleet/frontend</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/moofasa</string>
        <key>NODE_ENV</key>
        <string>development</string>
    </dict>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>3</integer>

    <key>StandardOutPath</key>
    <string>/Users/moofasa/claude-devfleet/data/logs/ui.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/moofasa/claude-devfleet/data/logs/ui-error.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
